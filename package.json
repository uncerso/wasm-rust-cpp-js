{
  "name": "wasm-rust-cpp-js",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --parallel test",
    "build:js": "tsx scripts/build-js.ts",
    "build:rust": "tsx scripts/build-rust.ts",
    "build:cpp": "tsx scripts/build-cpp.ts",
    "build:all": "tsx scripts/build-all.ts",
    "collect-sizes": "tsx scripts/collect-sizes.ts",
    "generate-fixtures": "tsx scripts/generate-fixtures.ts",
    "smoke": "tsx scripts/smoke.ts",
    "clear": "tsx scripts/clear.ts",
    "clear:all": "tsx scripts/clear.ts --all",
    "lint:ts": "eslint .",
    "lint:ts:fix": "eslint . --fix",
    "lint:rust": "cargo clippy --workspace --target wasm32-unknown-unknown -- -D warnings && cargo clippy -p matmul-shared --all-targets -- -D warnings",
    "lint:all": "pnpm lint:ts && pnpm lint:rust",
    "bench": "tsx scripts/run-matrix.ts",
    "report": "tsx scripts/report.ts",
    "bench:all": "pnpm build:all && pnpm bench --mode=eval && pnpm report"
  },
  "devDependencies": {
    "@bench/reporter": "workspace:^",
    "@bench/result-schema": "workspace:*",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^10.3.0",
    "execa": "^9.5.0",
    "globals": "^17.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.0.0",
    "wabt": "^1.0.39",
    "zod": "^3.23.8"
  }
}
